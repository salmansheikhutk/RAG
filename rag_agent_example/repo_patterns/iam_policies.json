{
  "data_science_team_policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "AllowDataScienceRead",
        "Effect": "Allow",
        "Principal": {
          "AWS": "arn:aws:iam::123456789012:role/DataScienceRole"
        },
        "Action": [
          "s3:GetObject",
          "s3:GetObjectVersion",
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:aws:s3:::analytics-*/*",
          "arn:aws:s3:::analytics-*"
        ]
      }
    ]
  },
  
  "backup_service_policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "AllowBackupServiceFullAccess",
        "Effect": "Allow",
        "Principal": {
          "AWS": "arn:aws:iam::123456789012:role/BackupServiceRole"
        },
        "Action": [
          "s3:PutObject",
          "s3:PutObjectAcl",
          "s3:GetObject",
          "s3:DeleteObject",
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:aws:s3:::app-backups-*/*",
          "arn:aws:s3:::app-backups-*"
        ]
      }
    ]
  },

  "development_team_policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "AllowDevTeamAccess",
        "Effect": "Allow",
        "Principal": {
          "AWS": [
            "arn:aws:iam::123456789012:role/DeveloperRole",
            "arn:aws:iam::123456789012:role/DevOpsRole"
          ]
        },
        "Action": [
          "s3:PutObject",
          "s3:GetObject", 
          "s3:DeleteObject",
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:aws:s3:::dev-*/*",
          "arn:aws:s3:::dev-*"
        ]
      }
    ]
  },

  "cross_account_replication_policy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "AllowReplicationService",
        "Effect": "Allow",
        "Principal": {
          "Service": "s3.amazonaws.com"
        },
        "Action": [
          "s3:GetObjectVersionForReplication",
          "s3:GetObjectVersionAcl"
        ],
        "Resource": "arn:aws:s3:::SOURCE_BUCKET_NAME/*"
      },
      {
        "Sid": "AllowReplicationDestination",
        "Effect": "Allow",
        "Principal": {
          "Service": "s3.amazonaws.com"
        },
        "Action": [
          "s3:ReplicateObject",
          "s3:ReplicateDelete"
        ],
        "Resource": "arn:aws:s3:::DEST_BUCKET_NAME/*"
      }
    ]
  }
}
